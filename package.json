{
  "name": "event-registration-platform",
  "version": "1.0.0",
  "description": "A platform for event organizers to create and manage registration forms.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev src/index.ts",
    "build": "tsc",
    "prestart": "npm run build && npm run db:migrate",
    "start": "node dist/index.js",
    "db:migrate": "knex migrate:latest --knexfile knexfile.js",
    "db:seed": "knex seed:run --knexfile knexfile.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.22.1",
    "express-session": "^1.17.3",
    "knex": "^3.0.1",
    "pg": "^8.17.2",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.4",
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.18",
    "@types/express-session": "^1.17.8",
    "@types/node": "^20.8.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
